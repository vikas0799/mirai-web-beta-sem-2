<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students Data</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            background: #f4f6f9;
            padding: 30px;
        }

        h1{
            text-align: center;
            margin-bottom: 25px;
            color: #333;
        }

        .home{
            display: inline-block;
            margin-bottom: 25px;
            padding: 10px 18px;
            background: #343a40;
            color: #fff;
            text-decoration: none;
            border-radius: 6px;
            transition: 0.3s;
        }

        .home:hover{
            background: #212529;
        }

        .container{
            max-width: 900px;
            margin: auto;
        }

        .card{
            background: #fff;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 5px 12px rgba(0,0,0,0.15);
        }

        .card p{
            margin: 10px 0;
            font-size: 17px;
            color: #444;
        }

        .card strong{
            color: #000;
        }

        .actions{
            margin-top: 20px;
        }

        .actions a{
            display: inline-block;
            text-decoration: none;
            color: white;
            padding: 10px 18px;
            border-radius: 6px;
            margin-right: 10px;
            font-weight: bold;
            transition: 0.3s;
        }

        .edit{
            background: #0d6efd;
        }

        .edit:hover{
            background: #0b5ed7;
        }

        .delete{
            background: #dc3545;
        }

        .delete:hover{
            background: #bb2d3b;
        }

        @media (max-width:600px){

            body{
                padding:15px;
            }

            .card{
                padding:15px;
            }

            .actions a{
                width:100%;
                text-align:center;
                margin-bottom:10px;
            }
        }
    </style>
</head>
<body>

    <h1>Students Data Profile</h1>

    <a href="/" class="home">🏠 Back to Home</a>

    <div class="container">

        <% allstudent.forEach((element)=>{ %>

            <div class="card">

                <p><strong>ID:</strong> <%= element._id %></p>

                <p><strong>Version:</strong> <%= element.__v %></p>

                <p><strong>Name:</strong> <%= element.name %></p>

                <p><strong>Age:</strong> <%= element.age %></p>

                <p><strong>Course:</strong> <%= element.course %></p>

                <p><strong>Email:</strong> <%= element.email %></p>

                <div class="actions">
                    <a href="/edit/<%= element._id %>" class="edit">✏️ Edit</a>
                    <a href="/delete/<%= element._id %>" class="delete">🗑️ Delete</a>
                </div>

            </div>

        <% }) %>

    </div>

</body>
</html>
      "link": null,
      "locked": false,
      "text": "// api calling -> fetch -> to send requests to servers.\nasync function getPosts(){\n  let response = await fetch(\"https://jsonplaceholder.typicode.com/posts\");\n  // console.log(response);\n  const data = await response.json();\n  console.log(data);\n}\n\ngetPosts();",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// api calling -> fetch -> to send requests to servers.\nasync function getPosts(){\n  let response = await fetch(\"https://jsonplaceholder.typicode.com/posts\");\n  // console.log(response);\n  const data = await response.json();\n  console.log(data);\n}\n\ngetPosts();",
      "autoResize": true,
      "lineHeight": 1.25
    },
